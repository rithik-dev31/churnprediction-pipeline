# Database Configuration
DATABASE_PATH=database/churn_prediction.db

# Application Configuration
APP_NAME=Customer Churn Prediction System
DEBUG=False
LOG_LEVEL=INFO

# Model Training Configuration
DEFAULT_TEST_SIZE=0.2
DEFAULT_CV_FOLDS=5
DEFAULT_RANDOM_STATE=42
DEFAULT_SCALING_METHOD=standard
DEFAULT_ENCODING_METHOD=label
DEFAULT_MISSING_VALUE_METHOD=mean

# Streamlit Configuration
STREAMLIT_MAX_UPLOAD_SIZE=200
STREAMLIT_THEME=light
STREAMLIT_LOGGER_LEVEL=info

# Feature Selection
ENABLE_FEATURE_SELECTION=False
DEFAULT_FEATURE_COUNT=10

# Model Paths
MODELS_DIR=models
DATASETS_DIR=datasets
LOGS_DIR=logs

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600

# Email Notifications (Optional)
EMAIL_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
